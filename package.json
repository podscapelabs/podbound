{
  "name": "podbound",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:access": "node --experimental-strip-types scripts/check-access-policy.ts",
    "test:my-lab": "node --experimental-strip-types scripts/check-my-lab-schema.ts",
    "test:auth-email": "node --experimental-strip-types scripts/check-auth-email-policy.ts",
    "test:redirects": "node --experimental-strip-types scripts/check-safe-redirects.ts",
    "test:public-data": "node --experimental-strip-types scripts/check-public-data-policy.ts",
    "test:account-deletion": "node --experimental-strip-types scripts/check-account-deletion-policy.ts",
    "test:accessibility": "node --experimental-strip-types scripts/check-accessibility-contracts.ts",
    "test:playtest-reports": "node --experimental-strip-types scripts/check-playtest-report-policy.ts",
    "test:security-headers": "node --experimental-strip-types scripts/check-security-headers.ts",
    "test": "pnpm run test:access && pnpm run test:my-lab && pnpm run test:auth-email && pnpm run test:redirects && pnpm run test:public-data && pnpm run test:account-deletion && pnpm run test:accessibility && pnpm run test:playtest-reports && pnpm run test:security-headers"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.7",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.1",
    "@types/node": "22.15.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3"
  },
  "engines": { "node": ">=20.9.0" }
}
